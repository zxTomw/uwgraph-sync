# Waterloo OpenData API
WATERLOO_API_KEY=
WATERLOO_BASE_URL=https://openapi.data.uwaterloo.ca

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Sync settings
# Comma-separated Waterloo term codes
UWGRAPH_TERM_CODES=1265,1261
UWGRAPH_SYNC_INTERVAL=6h
UWGRAPH_HTTP_TIMEOUT=30s
UWGRAPH_SYNC_TIMEOUT=30m
