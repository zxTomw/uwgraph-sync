# Waterloo OpenData API
WATERLOO_API_KEY=
WATERLOO_BASE_URL=https://openapi.data.uwaterloo.ca

# Neo4j
# Compose overrides this with bolt://neo4j:7687 for the app container.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-this-password
NEO4J_DATABASE=neo4j
# Optional host ports exposed by Compose
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Sync settings
# Comma-separated Waterloo term codes
UWGRAPH_TERM_CODES=1265,1261
UWGRAPH_SYNC_INTERVAL=6h
UWGRAPH_HTTP_TIMEOUT=30s
UWGRAPH_SYNC_TIMEOUT=30m
UWGRAPH_STARTUP_TIMEOUT=2m

# OpenAI-compatible embeddings endpoint
UWGRAPH_EMBEDDING_BASE_URL=https://api.openai.com/v1
UWGRAPH_EMBEDDING_API_KEY=
UWGRAPH_EMBEDDING_MODEL=text-embedding-3-small
UWGRAPH_EMBEDDING_DIMENSIONS=1536
UWGRAPH_EMBEDDING_BATCH_SIZE=64
UWGRAPH_EMBEDDING_TIMEOUT=30s
UWGRAPH_EMBEDDING_POLL_INTERVAL=1m

# Knowledge REST API and MCP
UWGRAPH_KNOWLEDGE_API_KEY=change-this-api-key
UWGRAPH_KNOWLEDGE_PORT=8080
UWGRAPH_KNOWLEDGE_QUERY_TIMEOUT=15s
# Comma-separated exact origins accepted by MCP requests; empty permits requests without Origin only.
UWGRAPH_MCP_ALLOWED_ORIGINS=
